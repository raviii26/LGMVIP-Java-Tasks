import javax.swing.*;
import java.awt.*;
import java.awt.event.*;
import java.util.Stack;

public class ScientificCalculator extends JFrame implements ActionListener {
    // Components of the calculator
    private JTextField display;

    // To keep track of operations and operands
    private StringBuilder input = new StringBuilder();
    
    public ScientificCalculator() {
        setTitle("Scientific Calculator");
        setSize(400, 600);
        setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        
        display = new JTextField();
        display.setFont(new Font("Arial", Font.PLAIN, 24));
        display.setEditable(false);
        display.setHorizontalAlignment(SwingConstants.RIGHT);
        
        JPanel panel = new JPanel();
        panel.setLayout(new GridLayout(6, 4, 10, 10));
        
        // Add buttons to the panel
        String[] buttonLabels = {
            "7", "8", "9", "/",
            "4", "5", "6", "*",
            "1", "2", "3", "-",
            "0", ".", "=", "+",
            "sin", "cos", "tan", "C"
        };
        
        for (String label : buttonLabels) {
            JButton button = new JButton(label);
            button.setFont(new Font("Arial", Font.PLAIN, 18));
            button.addActionListener(this);
            panel.add(button);
        }
        
        setLayout(new BorderLayout());
        add(display, BorderLayout.NORTH);
        add(panel, BorderLayout.CENTER);
    }

    public void actionPerformed(ActionEvent e) {
        String command = e.getActionCommand();
        
        if (command.equals("=")) {
            try {
                double result = evaluate(input.toString());
                display.setText(String.valueOf(result));
                input.setLength(0); // Clear the input
            } catch (Exception ex) {
                display.setText("Error");
                input.setLength(0); // Clear the input
            }
        } else if (command.equals("C")) {
            display.setText("");
            input.setLength(0); // Clear the input
        } else {
            input.append(command);
            display.setText(input.toString());
        }
    }
    
    // Basic evaluation method for expressions
    private double evaluate(String expression) throws Exception {
        // In a real-world application, use a proper parser like exp4j
        // Here we keep it simple for demonstration purposes
        Stack<Double> numbers = new Stack<>();
        Stack<Character> operations = new Stack<>();
        
        for (int i = 0; i < expression.length(); i++) {
            char ch = expression.charAt(i);
            
            if (Character.isDigit(ch)) {
                double num = 0;
                while (i < expression.length() && (Character.isDigit(expression.charAt(i)) || expression.charAt(i) == '.')) {
                    if (expression.charAt(i) == '.') {
                        i++;
                        double decimal = 0.1;
                        while (i < expression.length() && Character.isDigit(expression.charAt(i))) {
                            num += (expression.charAt(i) - '0') * decimal;
                            decimal *= 0.1;
                            i++;
                        }
                        i--;
                    } else {
                        num = num * 10 + (expression.charAt(i) - '0');
                    }
                    i++;
                }
                i--;
                numbers.push(num);
            } else if (ch == '(') {
                operations.push(ch);
            } else if (ch == ')') {
                while (operations.peek() != '(') {
                    numbers.push(applyOperation(operations.pop(), numbers.pop(), numbers.pop()));
                }
                operations.pop();
            } else if (ch == '+' || ch == '-' || ch == '*' || ch == '/') {
                while (!operations.isEmpty() && precedence(ch) <= precedence(operations.peek())) {
                    numbers.push(applyOperation(operations.pop(), numbers.pop(), numbers.pop()));
                }
                operations.push(ch);
            }
        }
        
        while (!operations.isEmpty()) {
            numbers.push(applyOperation(operations.pop(), numbers.pop(), numbers.pop()));
        }
        
        return numbers.pop();
    }

    private double applyOperation(char operation, double b, double a) {
        switch (operation) {
            case '+':
                return a + b;
            case '-':
                return a - b;
            case '*':
                return a * b;
            case '/':
                if (b == 0) throw new ArithmeticException("Cannot divide by zero");
                return a / b;
        }
        return 0;
    }

    private int precedence(char operation) {
        switch (operation) {
            case '+':
            case '-':
                return 1;
            case '*':
            case '/':
                return 2;
        }
        return -1;
    }
    
    public static void main(String[] args) {
        SwingUtilities.invokeLater(() -> {
            ScientificCalculator calculator = new ScientificCalculator();
            calculator.setVisible(true);
        });
    }
}
